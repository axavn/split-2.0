# Copy this file to `.env` and fill in the values from your Supabase project:
# Supabase dashboard -> Project Settings -> API.
#
# The VITE_ prefix is required: Vite only exposes env vars starting with VITE_
# to browser code (import.meta.env.*). Everything here is safe to be public —
# the anon key is designed to be shipped to browsers; Row Level Security in
# Postgres is what actually protects the data.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
